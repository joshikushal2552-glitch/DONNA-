# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI engines (optional — app falls back to sandbox mode without these)
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Google OAuth is configured in Supabase Dashboard → Authentication → Providers → Google
# Add your Vercel deployment URL to Supabase redirect URLs after deploying.
